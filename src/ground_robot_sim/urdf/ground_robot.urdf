<?xml version="1.0"?>
<robot name="ground_robot">
  <link name="base_link">
    <visual>
      <origin xyz="0 0 0.08" rpy="0 0 0"/>
      <geometry><box size="0.45 0.32 0.16"/></geometry>
      <material name="blue"><color rgba="0.1 0.3 0.9 1.0"/></material>
    </visual>
    <collision>
      <origin xyz="0 0 0.08" rpy="0 0 0"/>
      <geometry><box size="0.45 0.32 0.16"/></geometry>
    </collision>
  </link>

  <link name="base_scan">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><cylinder radius="0.06" length="0.04"/></geometry>
      <material name="black"><color rgba="0.02 0.02 0.02 1.0"/></material>
    </visual>
  </link>

  <joint name="base_to_scan" type="fixed">
    <parent link="base_link"/>
    <child link="base_scan"/>
    <origin xyz="0.18 0 0.12" rpy="0 0 0"/>
  </joint>
</robot>
