<?xml version="1.0"?>
<robot name="planar_manipulator">
  <link name="base_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.08" length="0.04"/>
      </geometry>
      <material name="base_gray">
        <color rgba="0.25 0.28 0.32 1.0"/>
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.08" length="0.04"/>
      </geometry>
    </collision>
  </link>

  <link name="link1">
    <visual>
      <origin xyz="0.4 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.8 0.04 0.04"/>
      </geometry>
      <material name="link_blue">
        <color rgba="0.1 0.35 0.85 1.0"/>
      </material>
    </visual>
    <collision>
      <origin xyz="0.4 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.8 0.04 0.04"/>
      </geometry>
    </collision>
    <inertial>
      <origin xyz="0.4 0 0" rpy="0 0 0"/>
      <mass value="1.0"/>
      <inertia ixx="0.001" ixy="0.0" ixz="0.0" iyy="0.055" iyz="0.0" izz="0.055"/>
    </inertial>
  </link>

  <link name="link2">
    <visual>
      <origin xyz="0.3 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.6 0.035 0.035"/>
      </geometry>
      <material name="link_green">
        <color rgba="0.05 0.55 0.32 1.0"/>
      </material>
    </visual>
    <collision>
      <origin xyz="0.3 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.6 0.035 0.035"/>
      </geometry>
    </collision>
    <inertial>
      <origin xyz="0.3 0 0" rpy="0 0 0"/>
      <mass value="0.8"/>
      <inertia ixx="0.001" ixy="0.0" ixz="0.0" iyy="0.024" iyz="0.0" izz="0.024"/>
    </inertial>
  </link>

  <link name="tool0">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <sphere radius="0.045"/>
      </geometry>
      <material name="tool_orange">
        <color rgba="0.95 0.45 0.1 1.0"/>
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <sphere radius="0.045"/>
      </geometry>
    </collision>
  </link>

  <joint name="joint1" type="revolute">
    <parent link="base_link"/>
    <child link="link1"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-3.14159" upper="3.14159" effort="10.0" velocity="1.2"/>
  </joint>

  <joint name="joint2" type="revolute">
    <parent link="link1"/>
    <child link="link2"/>
    <origin xyz="0.8 0 0" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-3.14159" upper="3.14159" effort="10.0" velocity="1.2"/>
  </joint>

  <joint name="tool0_fixed" type="fixed">
    <parent link="link2"/>
    <child link="tool0"/>
    <origin xyz="0.6 0 0" rpy="0 0 0"/>
  </joint>
</robot>
